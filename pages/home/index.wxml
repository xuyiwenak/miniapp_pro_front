<nav title-text="范例展示" />

<!-- 节点一：起艺名引导弹窗 -->
<view class="ob-mask" wx:if="{{showNicknameGuide}}" bindtap="onSkipNickname">
  <view class="ob-card" catchtap="" style="height: 902rpx; display: block; box-sizing: border-box">
    <text class="ob-title">给自己起个昵称吧</text>
    <text class="ob-subtitle">这将是你的身份</text>
    <input style="height: 35rpx; display: block; box-sizing: border-box" class="ob-input" placeholder="输入你的昵称" value="{{draftNickname}}"
      bindinput="onNicknameInput" maxlength="20" />
    <view class="ob-actions">
      <view class="ob-btn ob-btn--ghost" bindtap="onSkipNickname">跳过</view>
      <view class="ob-btn ob-btn--primary" bindtap="onSaveNickname">完成</view>
    </view>
  </view>
</view>

<view class="home-container">
  <scroll-view
    class="home-scroll"
    scroll-y
    enhanced
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    refresher-default-style="black"
    bindrefresherrefresh="onPullDownRefresh"
  >
    <view class="home-grid" wx:if="{{cardInfo.length > 0}}">
      <view
        class="home-grid__item"
        wx:for="{{cardInfo}}"
        wx:key="workId"
        bindtap="onCardTap"
        data-work-id="{{item.workId}}"
      >
        <view class="home-grid__img-wrap">
          <image class="home-grid__image" src="{{item.url}}" mode="aspectFill" lazy-load />
        </view>
        <view class="home-grid__info">
          <text class="home-grid__title">{{item.desc || '无标题作品'}}</text>
          <view class="home-grid__tags" wx:if="{{item.tags && item.tags.length}}">
            <text
              class="home-grid__tag"
              wx:for="{{item.tags}}"
              wx:for-item="tag"
              wx:key="text"
            >{{tag.text}}</text>
          </view>
          <view class="home-grid__author">
            <view class="home-grid__avatar" />
            <text class="home-grid__nickname">{{item.nickname || '匿名'}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="home-empty" wx:else>
      <text>加载中...</text>
    </view>
  </scroll-view>
</view>

<t-message id="t-message" />

<t-navbar left-arrow />
<view class="page bind">
  <view class="bind__title">完善登录</view>

  <view wx:if="{{mode === 'choice'}}" class="bind__card">
    <view class="bind__desc">检测到该微信未绑定账号，请选择：</view>
    <t-button theme="primary" size="large" block loading="{{loading}}" bindtap="createNewAccount">
      创建新账号并登录
    </t-button>
    <view style="height: 24rpx;" />
    <t-button theme="default" variant="outline" size="large" block disabled="{{loading}}" bindtap="toBindMode">
      绑定已有账号
    </t-button>
  </view>

  <view wx:elif="{{mode === 'bind'}}" class="bind__card">
    <view class="bind__desc">输入已有账号密码完成绑定</view>
    <t-input label="账号" placeholder="请输入账号" value="{{account}}" bindchange="onAccountChange" />
    <t-input label="密码" placeholder="请输入密码" type="password" value="{{password}}" bindchange="onPasswordChange" />

    <view style="height: 24rpx;" />
    <t-button theme="primary" size="large" block loading="{{loading}}" bindtap="bindExistingAccount">
      绑定并登录
    </t-button>
    <view style="height: 16rpx;" />
    <t-button theme="default" variant="outline" size="large" block disabled="{{loading}}" bindtap="backToChoice">
      返回
    </t-button>
  </view>
</view>


<t-toast id="t-toast" />

<!-- MBTI 引导弹窗（昵称引导完成后触发，可跳过） -->
<view class="ob-mask" wx:if="{{showMbtiGuide}}">
  <view class="ob-card">
    <block wx:if="{{mbtiGuideMode === 'select'}}">
      <text class="ob-title">✨ 完善你的人格档案</text>
      <text class="ob-subtitle">添加 MBTI 让大家更了解你，也可以稍后再填</text>
      <view class="ob-tags">
        <view
          wx:for="{{mbtiOptions}}" wx:key="*this"
          class="ob-tag {{draftMbti === item ? 'ob-tag--active' : ''}}"
          data-mbti="{{item}}" bindtap="onMbtiGuideSelect">{{item}}</view>
      </view>
      <view class="ob-hint" bindtap="onSwitchMbtiTest">不知道自己的 MBTI？去测一测 →</view>
      <view class="ob-actions">
        <view class="ob-btn ob-btn--ghost" bindtap="onSkipMbtiGuide">跳过</view>
        <view class="ob-btn ob-btn--primary" bindtap="onSaveMbtiFromGuide">保存</view>
      </view>
    </block>
    <block wx:elif="{{mbtiGuideMode === 'test'}}">
      <text class="ob-title">🧠 发现你的人格类型</text>
      <text class="ob-subtitle">做一个简短的测试，结果将永久保存到你的档案</text>
      <view class="ob-test-illus">
        <text class="ob-test-illus__icon">🎨</text>
        <text class="ob-test-illus__text">测试只需 3 分钟，完成后自动记录结果</text>
      </view>
      <view class="ob-btn ob-btn--primary" style="margin-bottom:20rpx;" bindtap="onGoMbtiTestFromGuide">开始测试</view>
      <view class="ob-back" bindtap="onSwitchMbtiSelect">← 我知道我的 MBTI，直接选</view>
      <view class="ob-btn ob-btn--ghost" style="margin-top:24rpx;" bindtap="onSkipMbtiGuide">跳过</view>
    </block>
  </view>
</view>

<view class="my">
  <view class="profile-bg">
    <image
      class="profile-bg__img"
      src="{{personalInfo.photos[0].url || '/static/img_td.png'}}"
      mode="aspectFill"
      aria-hidden="true"
    />
    <view class="profile-bg__mask" />
  </view>

  <!-- 个人资料区 -->
  <view class="profile-section">
    <!-- 已登录 -->
    <block wx:if="{{isLoad}}">
      <!-- 第一行：头像 + 编辑按钮 + 齿轮 -->
      <view class="profile-row-top">
        <view class="profile-avatar" bindtap="onAvatarTap">
          <t-avatar image="{{personalInfo.image}}" size="144rpx" />
        </view>
        <view class="profile-actions">
          <view class="profile-edit-btn" bindtap="onNavigateTo">
            <t-icon name="edit" size="28rpx" color="#333" />
            <text>编辑资料</text>
          </view>
          <view class="profile-setting-btn" bindtap="onSettingTap">
            <t-icon name="setting" size="40rpx" color="#555" />
          </view>
        </view>
      </view>

      <!-- 用户名 -->
      <view class="profile-name">{{personalInfo.name}}</view>

      <!-- 标签行：星座 + MBTI -->
      <view class="profile-tags">
        <view wx:if="{{personalInfo.star}}" class="tag-pill">
          <text class="tag-pill__emoji">{{personalInfo.starEmoji}}</text>
          <text class="tag-pill__text">{{personalInfo.star}}</text>
        </view>
        <view class="tag-pill tag-pill--mbti" bindtap="onMbtiTap">
          <text wx:if="{{personalInfo.mbtiEmoji}}" class="tag-pill__emoji">{{personalInfo.mbtiEmoji}}</text>
          <text class="tag-pill__text">{{personalInfo.mbti || 'MBTI 未知'}}</text>
        </view>
      </view>

      <!-- 简介 -->
      <view class="profile-brief" wx:if="{{personalInfo.brief}}">
        {{personalInfo.brief}}
      </view>
    </block>

    <!-- 未登录 -->
    <block wx:else>
      <view class="profile-row-top">
        <view class="profile-avatar">
          <t-avatar icon="user" size="144rpx" />
        </view>
      </view>
      <view class="profile-name profile-name--login" bindtap="onLogin">点击登录 / 注册</view>
    </block>
  </view>

  <!-- 作品区 -->
  <view class="func-section">
    <view class="work-grid">
      <view class="work-grid__loading" wx:if="{{worksLoading}}">加载中...</view>
      <view class="work-grid__empty" wx:elif="{{!workList.length}}">暂无作品</view>
      <view class="work-grid__list" wx:else>
        <view
          class="work-grid__item"
          wx:for="{{workList}}"
          wx:for-item="work"
          wx:key="workId"
          bindtap="onWorkTap"
          data-work-id="{{work.workId}}"
        >
          <view class="work-grid__img-wrap">
            <image class="work-grid__img" src="{{work.coverUrl}}" mode="aspectFill" lazy-load aria-label="{{work.desc || '作品图片'}}" />
          </view>
          <view class="work-grid__bottom">
            <text class="work-grid__desc">{{work.desc || '无标题作品'}}</text>
            <view class="work-grid__del" catchtap="onDeleteTap" data-work-id="{{work.workId}}">
              <t-icon name="delete" size="32rpx" color="#bbb" />
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

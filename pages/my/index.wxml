<t-toast id="t-toast" />

<view class="my">
  <view class="profile-bg">
    <image
      class="profile-bg__img"
      src="{{personalInfo.photos[0].url || '/static/img_td.png'}}"
      mode="aspectFill"
    />
    <view class="profile-bg__mask" />
  </view>

  <!-- 个人资料区 -->
  <view class="profile-section">
    <!-- 已登录 -->
    <block wx:if="{{isLoad}}">
      <!-- 第一行：头像 + 编辑按钮 + 齿轮 -->
      <view class="profile-row-top">
        <view class="profile-avatar" bindtap="onAvatarTap">
          <t-avatar image="{{personalInfo.image}}" size="144rpx" />
        </view>
        <view class="profile-actions">
          <view class="profile-edit-btn" bindtap="onNavigateTo">
            <t-icon name="edit" size="28rpx" color="#333" />
            <text>编辑资料</text>
          </view>
          <view class="profile-setting-btn" bindtap="onSettingTap">
            <t-icon name="setting" size="40rpx" color="#555" />
          </view>
        </view>
      </view>

      <!-- 用户名 -->
      <view class="profile-name">{{personalInfo.name}}</view>

      <!-- 标签行：星座 + MBTI -->
      <view class="profile-tags">
        <view wx:if="{{personalInfo.star}}" class="tag-pill">
          <text class="tag-pill__emoji">{{personalInfo.starEmoji}}</text>
          <text class="tag-pill__text">{{personalInfo.star}}</text>
        </view>
        <view class="tag-pill tag-pill--mbti" bindtap="onMbtiTap">
          <text wx:if="{{personalInfo.mbtiEmoji}}" class="tag-pill__emoji">{{personalInfo.mbtiEmoji}}</text>
          <text class="tag-pill__text">{{personalInfo.mbti || 'MBTI 未知'}}</text>
        </view>
      </view>

      <!-- 简介 -->
      <view class="profile-brief" wx:if="{{personalInfo.brief}}">
        {{personalInfo.brief}}
      </view>
    </block>

    <!-- 未登录 -->
    <block wx:else>
      <view class="profile-row-top">
        <view class="profile-avatar">
          <t-avatar icon="user" size="144rpx" />
        </view>
      </view>
      <view class="profile-name profile-name--login" bindtap="onLogin">点击登录 / 注册</view>
    </block>
  </view>

  <!-- Tab 栏 + 内容区 -->
  <view class="func-section">
    <!-- XHS 风格 Tab -->
    <view class="tab-bar">
      <view
        class="tab-bar__item {{activeTab === index ? 'tab-bar__item--active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="*this"
        bindtap="onTabTap"
        data-index="{{index}}"
      >
        <text class="tab-bar__label">{{item}}</text>
        <view class="tab-bar__line" wx:if="{{activeTab === index}}" />
      </view>
    </view>

    <!-- 作品列表（已上传 / 草稿箱） -->
    <view class="work-grid" wx:if="{{activeTab !== 2}}">
      <view class="work-grid__loading" wx:if="{{worksLoading}}">加载中...</view>
      <view class="work-grid__empty" wx:elif="{{!workList.length}}">暂无作品</view>
      <view class="work-grid__list" wx:else>
        <view
          class="work-grid__item"
          wx:for="{{workList}}"
          wx:for-item="work"
          wx:key="workId"
          bindtap="onWorkTap"
          data-work-id="{{work.workId}}"
        >
          <view class="work-grid__img-wrap">
            <image class="work-grid__img" src="{{work.coverUrl}}" mode="aspectFill" lazy-load />
          </view>
          <view class="work-grid__desc">{{work.desc || '无标题作品'}}</view>
        </view>
      </view>
    </view>
  </view>
</view>

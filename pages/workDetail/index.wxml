<!-- 节点三：MBTI 引导弹窗 -->
<view class="ob-mask" wx:if="{{showMbtiGuide}}">
  <view class="ob-card">
    <!-- 子状态 A：我知道我的 MBTI -->
    <block wx:if="{{!mbtiGuideMode || mbtiGuideMode === 'select'}}">
      <text class="ob-title">✨ 加入你的 MBTI</text>
      <text class="ob-subtitle">AI 将从人格视角解读作品与你内心的联结</text>
      <view class="ob-tags">
        <view
          wx:for="{{mbtiOptions}}" wx:key="*this"
          class="ob-tag {{draftMbti === item ? 'ob-tag--active' : ''}}"
          data-mbti="{{item}}" bindtap="onMbtiSelect">{{item}}</view>
      </view>
      <view class="ob-hint" bindtap="onSwitchMbtiTest">不知道自己的 MBTI？去测一测 →</view>
      <view class="ob-actions">
        <view class="ob-btn ob-btn--ghost" bindtap="onSkipMbti">跳过</view>
        <view class="ob-btn ob-btn--primary" bindtap="onSaveMbti">确认并分析</view>
      </view>
    </block>

    <!-- 子状态 B：引导去测试 -->
    <block wx:elif="{{mbtiGuideMode === 'test'}}">
      <text class="ob-title">🧠 发现你的人格类型</text>
      <text class="ob-subtitle">做一个简短的测试，AI 分析会更懂你</text>
      <view class="ob-test-illus">
        <text class="ob-test-illus__icon">🎨</text>
        <text class="ob-test-illus__text">测试只需 3 分钟，结果将永久保存到你的档案</text>
      </view>
      <view class="ob-btn ob-btn--primary" style="margin-bottom:20rpx;" bindtap="onGoMbtiTest">开始测试</view>
      <view class="ob-back" bindtap="onSwitchMbtiSelect">← 我知道我的 MBTI，直接选</view>
      <view class="ob-btn ob-btn--ghost" style="margin-top:24rpx;" bindtap="onSkipMbti">跳过</view>
    </block>
  </view>
</view>

<view class="work-detail" wx:if="{{!loading && !error && work}}">
  <view class="work-detail__media">
    <block wx:if="{{work.images && work.images.length > 0}}">
      <t-image
        wx:if="{{work.images.length === 1}}"
        class="work-detail__cover"
        src="{{work.images[0].url}}"
        mode="widthFix"
      />
      <swiper wx:else class="work-detail__swiper" indicator-dots autoplay circular>
        <swiper-item wx:for="{{work.images}}" wx:key="url">
          <t-image class="work-detail__slide-img" src="{{item.url}}" mode="aspectFit" />
        </swiper-item>
      </swiper>
    </block>
    <view wx:else class="work-detail__no-image">暂无图片</view>
  </view>
  <view class="work-detail__ai">
    <view class="work-detail__ai-header">
      <view class="work-detail__ai-title">
        <text class="work-detail__ai-label">分析结果</text>
      </view>
      <view class="work-detail__ai-action">
        <block wx:if="{{healingStatus === 'none' && !healingLoading}}">
          <block wx:if="{{isOwner}}">
            <text class="work-detail__ai-status">未做内容分析</text>
            <button class="work-detail__ai-button" size="mini" bindtap="onAnalyzeTap">点击分析</button>
            <view class="work-detail__ai-privacy-toggle" bindtap="onTogglePrivacyTap">
              <t-icon name="{{healingIsPublic ? 'browse' : 'browse-off'}}" size="40rpx" class="work-detail__ai-eye-icon work-detail__ai-eye-icon--tap" />
            </view>
          </block>
          <block wx:else>
            <t-icon name="browse-off" size="32rpx" class="work-detail__ai-eye-icon" />
            <text class="work-detail__ai-status work-detail__ai-status--muted">分析不可见</text>
          </block>
        </block>
        <block wx:elif="{{healingStatus === 'pending' || healingLoading}}">
          <block wx:if="{{isOwner}}">
            <view class="work-detail__ai-privacy-toggle" bindtap="onTogglePrivacyTap">
              <t-icon name="{{healingIsPublic ? 'browse' : 'browse-off'}}" size="40rpx" class="work-detail__ai-eye-icon work-detail__ai-eye-icon--tap" />
            </view>
          </block>
          <block wx:else>
            <t-icon name="browse-off" size="32rpx" class="work-detail__ai-eye-icon" />
            <text class="work-detail__ai-status work-detail__ai-status--muted">分析不可见</text>
          </block>
        </block>
        <block wx:elif="{{healingAnalyzed && !healingVisible}}">
          <block wx:if="{{isOwner}}">
            <view class="work-detail__ai-privacy-toggle" bindtap="onTogglePrivacyTap">
              <t-icon name="{{healingIsPublic ? 'browse' : 'browse-off'}}" size="40rpx" class="work-detail__ai-eye-icon work-detail__ai-eye-icon--tap" />
            </view>
          </block>
          <block wx:else>
            <t-icon name="browse-off" size="32rpx" class="work-detail__ai-eye-icon" />
            <text class="work-detail__ai-status work-detail__ai-status--muted">分析不可见</text>
          </block>
        </block>
        <block wx:elif="{{healingAnalyzed && healingVisible}}">
          <text class="work-detail__ai-status">
            {{healingDominantEmotionLabel}} {{healingDominantEmotionScore}}%
          </text>
        </block>
      </view>
    </view>
    <!-- Progress bar shown while analysis is in progress -->
    <view class="heal-progress" wx:if="{{(healingStatus === 'pending' || healingLoading) && isOwner}}">
      <view class="heal-progress__header">
        <text class="heal-progress__label">正在解读你的作品</text>
        <text class="heal-progress__time" wx:if="{{healingRemainingSeconds > 0}}">约 {{healingRemainingLabel}}</text>
        <text class="heal-progress__time" wx:else>即将完成</text>
      </view>
      <view class="heal-progress__track">
        <view class="heal-progress__fill" style="width: {{healingProgress}}%;" />
      </view>
    </view>
    <view wx:if="{{healingVisible && healingAnalyzed && !(healingStatus === 'pending' || healingLoading)}}">
      <healing-report-card
        visible="{{true}}"
        scores="{{healingScores}}"
        scoreDimensions="{{healingScoreDimensions}}"
        summary="{{healingSummary}}"
        colorAnalysis="{{healingColorAnalysis}}"
        compositionReport="{{healingCompositionReport}}"
        lineAnalysis="{{healingLineAnalysis}}"
        suggestion="{{healingSuggestion}}"
        keyColors="{{healingKeyColors}}"
        isPublic="{{healingIsPublic}}"
        canTogglePrivacy="{{isOwner}}"
        dominantEmotion="{{healingDominantEmotion}}"
        dominantEmotionLabel="{{healingDominantEmotionLabel}}"
        dominantEmotionScore="{{healingDominantEmotionScore}}"
        bind:toggleprivacy="onTogglePrivacy"
      />
    </view>
    <view wx:if="{{healingError}}" class="work-detail__ai-error">
      {{healingError}}
    </view>
  </view>
  <view class="work-detail__info">
    <text class="work-detail__desc">{{work.desc}}</text>
    <view class="work-detail__tags" wx:if="{{work.tags && work.tags.length}}">
      <t-tag wx:for="{{work.tags}}" wx:key="index" size="small" variant="light">{{item}}</t-tag>
    </view>
    <view class="work-detail__meta" wx:if="{{work.createdAtDisplay}}">
      <text>{{work.createdAtDisplay}}</text>
    </view>
  </view>
</view>
<view class="work-detail work-detail--loading" wx:elif="{{loading}}">
  <text>加载中...</text>
</view>
<view class="work-detail work-detail--error" wx:else>
  <text>{{error || '作品不存在或已下架'}}</text>
</view>

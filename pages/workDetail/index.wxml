<view class="work-detail" wx:if="{{!loading && !error && work}}">
  <view class="work-detail__media">
    <block wx:if="{{work.images && work.images.length > 0}}">
      <t-image
        wx:if="{{work.images.length === 1}}"
        class="work-detail__cover"
        src="{{work.images[0].url}}"
        mode="widthFix"
      />
      <swiper wx:else class="work-detail__swiper" indicator-dots autoplay circular>
        <swiper-item wx:for="{{work.images}}" wx:key="url">
          <t-image class="work-detail__slide-img" src="{{item.url}}" mode="aspectFit" />
        </swiper-item>
      </swiper>
    </block>
    <view wx:else class="work-detail__no-image">暂无图片</view>
  </view>
  <view class="work-detail__ai">
    <view class="work-detail__ai-header">
      <view class="work-detail__ai-title">
        <text class="work-detail__ai-label">分析结果</text>
      </view>
      <view class="work-detail__ai-action">
        <block wx:if="{{healingStatus === 'none' && !healingLoading}}">
          <text class="work-detail__ai-status">未做内容分析</text>
          <button class="work-detail__ai-button" size="mini" bindtap="onAnalyzeTap">点击分析</button>
        </block>
        <block wx:elif="{{healingStatus === 'pending' || healingLoading}}">
          <text class="work-detail__ai-status">分析中...</text>
        </block>
        <block wx:elif="{{healingAnalyzed && !healingVisible}}">
          <text class="work-detail__ai-status work-detail__ai-status--muted">
            作者将本次疗愈分析设为私密，仅自己可见
          </text>
        </block>
        <block wx:elif="{{healingAnalyzed && healingVisible && healingScores}}">
          <text class="work-detail__ai-status">
            {{healingDominantEmotionLabel}} {{healingDominantEmotionScore}}%
          </text>
        </block>
      </view>
    </view>
    <view wx:if="{{healingVisible && healingScores}}">
      <healing-report-card
        visible="{{true}}"
        scores="{{healingScores}}"
        summary="{{healingSummary}}"
        colorAnalysis="{{healingColorAnalysis}}"
        compositionReport="{{healingCompositionReport}}"
        lineAnalysis="{{healingLineAnalysis}}"
        suggestion="{{healingSuggestion}}"
        keyColors="{{healingKeyColors}}"
        isPublic="{{healingIsPublic}}"
        canTogglePrivacy="{{isOwner}}"
        dominantEmotion="{{healingDominantEmotion}}"
        dominantEmotionLabel="{{healingDominantEmotionLabel}}"
        dominantEmotionScore="{{healingDominantEmotionScore}}"
        bind:toggleprivacy="onTogglePrivacy"
      />
    </view>
    <view wx:if="{{healingError}}" class="work-detail__ai-error">
      {{healingError}}
    </view>
  </view>
  <view class="work-detail__info">
    <text class="work-detail__desc">{{work.desc}}</text>
    <view class="work-detail__tags" wx:if="{{work.tags && work.tags.length}}">
      <t-tag wx:for="{{work.tags}}" wx:key="index" size="small" variant="light">{{item}}</t-tag>
    </view>
    <view class="work-detail__meta" wx:if="{{work.createdAtDisplay}}">
      <text>{{work.createdAtDisplay}}</text>
    </view>
  </view>
</view>
<view class="work-detail work-detail--loading" wx:elif="{{loading}}">
  <text>加载中...</text>
</view>
<view class="work-detail work-detail--error" wx:else>
  <text>{{error || '作品不存在或已下架'}}</text>
</view>

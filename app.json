{
  "lazyCodeLoading": "requiredComponents",
  "pages": [
    "pages/upload/index",
    "pages/home/index",
    "pages/my/index"
  ],
  "usingComponents": {
    "t-toast": "tdesign-miniprogram/toast/toast"
  },
  "subpackages": [
    {
      "root": "pages/workDetail",
      "name": "workDetail",
      "pages": ["index"]
    },
    {
      "root": "pages/feedback",
      "name": "feedback",
      "pages": ["index"]
    },
    {
      "root": "pages/mbti",
      "name": "mbti",
      "pages": ["index"]
    },
    {
      "root": "pages/my/info-edit",
      "name": "edit",
      "pages": ["index"]
    },
    {
      "root": "pages/login",
      "name": "login",
      "pages": ["login", "bindChoice"]
    },
    {
      "root": "pages/loginCode",
      "name": "loginCode",
      "pages": ["loginCode"]
    },
    {
      "root": "pages/dataCenter",
      "name": "dataCenter",
      "pages": ["index"]
    },
    {
      "root": "pages/setting",
      "name": "setting",
      "pages": ["index"]
    },
    {
      "root": "pages/release",
      "name": "release",
      "pages": ["index"]
    },
    {
      "root": "pages/ai-list",
      "name": "healing",
      "pages": ["index"]
    },
    {
      "root": "pages/work-list",
      "name": "works",
      "pages": ["index"]
    }
  ],
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#fff",
    "navigationBarTitleText": "Weixin",
    "navigationBarTextStyle": "black"
  },
  "tabBar": {
    "custom": true,
    "list": [
      {
        "pagePath": "pages/upload/index",
        "text": "上传作品"
      },
      {
        "pagePath": "pages/home/index",
        "text": "作品范例"
      },
      {
        "pagePath": "pages/my/index",
        "text": "我的"
      }
    ]
  },
  "resolveAlias": {
    "~/*": "/*"
  },
  "sitemapLocation": "sitemap.json"
}

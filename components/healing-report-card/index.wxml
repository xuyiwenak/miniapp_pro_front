<view class="healing-card" wx:if="{{visible}}">
  <view class="healing-card__header">
    <view class="healing-card__title">
      <t-icon name="chart-radar" size="40rpx" />
      <text class="healing-card__title-text">分析结果</text>
    </view>
    <view class="healing-card__privacy" wx:if="{{canTogglePrivacy}}">
      <text class="healing-card__privacy-label">{{ isPublic ? '公域可见' : '仅自己可见' }}</text>
      <t-switch size="small" value="{{isPublic}}" bind:change="onPrivacyChange" />
    </view>
  </view>

  <view class="healing-card__radar">
    <canvas
      canvas-id="radarCanvas"
      class="healing-card__canvas"
      style="width: {{canvasSize}}px; height: {{canvasSize}}px;"
    ></canvas>
  </view>

  <view class="healing-card__chip" wx:if="{{dominantEmotionLabel}}">
    <text class="healing-card__chip-label">{{ dominantEmoji }} {{ dominantEmotionLabel }}</text>
    <text class="healing-card__chip-score">{{ dominantEmotionScore }}%</text>
  </view>

  <view class="healing-card__section">
    <view class="healing-card__section-title">核心结论</view>
    <view class="healing-card__section-content">{{summary}}</view>
  </view>

  <view class="healing-card__section">
    <view class="healing-card__section-title">色彩分析</view>
    <view class="healing-card__section-content">{{colorAnalysis}}</view>
  </view>

  <view class="healing-card__section" wx:if="{{compositionReport}}">
    <view class="healing-card__section-title">构图分析</view>
    <view class="healing-card__section-content">{{compositionReport}}</view>
  </view>

  <view class="healing-card__section" wx:if="{{lineAnalysis && (lineAnalysis.interpretation || lineAnalysis.style || lineAnalysis.energy_score != null)}}">
    <view class="healing-card__section-title">线条与能量</view>
    <view class="healing-card__section-content">
      <block wx:if="{{lineAnalysis.interpretation}}">{{lineAnalysis.interpretation}}</block>
      <block wx:if="{{lineAnalysis.style}}"> 风格：{{lineAnalysis.style}}</block>
      <block wx:if="{{lineAnalysis.energy_score != null}}"> 能量值：{{lineAnalysis.energy_score}}</block>
    </view>
  </view>

  <view class="healing-card__section" wx:if="{{suggestion}}">
    <view class="healing-card__section-title">建议</view>
    <view class="healing-card__section-content">{{suggestion}}</view>
  </view>

  <view class="healing-card__section" wx:if="{{keyColors && keyColors.length > 0}}">
    <view class="healing-card__section-title">主色</view>
    <view class="healing-card__tags">
      <text class="healing-card__tag" wx:for="{{keyColors}}" wx:key="*this">{{item}}</text>
    </view>
  </view>
</view>


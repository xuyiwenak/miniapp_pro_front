<view class="tab-bar">
  <view class="tab-bar__item {{value === 'upload' ? 'tab-bar__item--active' : ''}}" bindtap="handleChange" data-value="upload">
    <t-icon name="upload" size="48rpx" />
    <text class="tab-bar__label">上传作品</text>
  </view>

  <view class="tab-bar__item {{value === 'my' ? 'tab-bar__item--active' : ''}}" bindtap="handleChange" data-value="my">
    <t-icon name="user" size="48rpx" />
    <text class="tab-bar__label">我的</text>
  </view>
</view>
